<?xml version="1.0" encoding="utf-8"?>
<!--
  HTTP to a LAN backend (e.g. http://192.168.x.x:8000) requires cleartext until the API
  is served over HTTPS. For production/public networks, terminate TLS on the server and
  then set base-config cleartextTrafficPermitted to false below.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
