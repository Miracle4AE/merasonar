# MeraSonar AI Assistant — örnek ortam değişkenleri (gerçek key'leri buraya yazmayın)

# OpenAI — gerçek anahtarı yalnızca yerel .env dosyasına yazın (asla .env.example'a koymayın)
OPENAI_API_KEY=
OPENAI_MODEL=

# AI Assistant
AI_ASSISTANT_ENABLED=false
AI_TIMEOUT_SECONDS=25
AI_MAX_TOKENS=1800
AI_TEMPERATURE=0.2
PROMPT_VERSION=v1
VISION_ENABLED=false
STREAMING_ENABLED=false
CACHE_TTL=900

# Opsiyonel maliyet tahmini (USD / 1M token)
AI_COST_INPUT_PER_1M=0
AI_COST_OUTPUT_PER_1M=0

# Rate limit (varsayılan kapalı)
AI_RATE_LIMIT_ENABLED=false
AI_RATE_LIMIT_PER_MINUTE=30

# Cost guard — tahmini istek maliyeti üst sınırı USD (0 = kapalı)
AI_MAX_ESTIMATED_COST_PER_REQUEST_USD=0

# Günlük kota (varsayılan kapalı)
AI_QUOTA_ENABLED=false
AI_FREE_DAILY_LIMIT=10
AI_PREMIUM_DAILY_LIMIT=100

# Telemetri kalıcılığı (varsayılan kapalı)
AI_TELEMETRY_PERSIST_ENABLED=false
AI_TELEMETRY_JSONL_PATH=run_logs/ai_telemetry.jsonl

# Usage summary admin koruması (boş = local/dev friendly)
AI_USAGE_ADMIN_KEY=

# Captain Atlas (Phase 8)
CAPTAIN_ATLAS_PERSONA_VERSION=captain_atlas_v1
MARINE_AI_COMMENT_CACHE_TTL_MINUTES=15

# Marine Intelligence (Faz 7a)
MARINE_INTELLIGENCE_ENABLED=true
MARINE_INTELLIGENCE_CACHE_TTL_MINUTES=30
OPEN_METEO_ENABLED=true
ASTRONOMY_LOCAL_ENABLED=true
MGM_ENABLED=false
WINDY_ENABLED=false
WINDY_APP_ENABLED=false
POSEIDON_ENABLED=false
# WINDY_API_KEY=
# POSEIDON_API_KEY=

# Saved Spots (Faz 7c)
MARINE_SAVED_SPOTS_ENABLED=true
MARINE_SPOT_STORAGE_BACKEND=sqlite
MARINE_SPOT_STORAGE_PATH=run_logs/marine_spots.db

# Catch Intelligence (Faz 8c)
MARINE_CATCH_STORAGE_ENABLED=true

# Bulk learning summaries (Faz 8d)
MARINE_BULK_LEARNING_SUMMARY_ENABLED=true

# Marine Compare (Faz 8e)
MARINE_COMPARE_ENABLED=true

# Tide provider (WorldTides — API key olmadan disabled kalır)
TIDE_PROVIDER_ENABLED=false
TIDE_PROVIDER_NAME=world_tides
TIDE_API_KEY=
TIDE_API_BASE_URL=https://www.worldtides.info/api/v3
TIDE_CACHE_TTL_MINUTES=60
